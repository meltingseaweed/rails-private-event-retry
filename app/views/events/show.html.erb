
<h1>About this event:</h1>
<p>At <%= @event.location%> and on <%= @event.event_date %></p>
<h2>People joining this event:</h2>

    <% if @event.attendees.any? %>
        <ul>
            <% @event.attendees.each do |attendee| %>
                <li><%= attendee.username %></li>
            <% end %>
        </ul>
    <% else %>
        <p>There is currently nobody joining.</p>
    <% end %>
</ul>
<%# Can add a class to the button for styling? %>
<hr>
<% if @creator == true %>
    <% if @all_users.exists? %>
        <h2>Would you like to invite anyone to your event?</h2>
            <ul>
                <% @all_users.each do |user| %>
                    <% if !@event.attendees.where(id: user.id).any? && user != current_user%>
                        <% if !@event.invited_users.where(id: user.id).any? %>
                            <p><%= user.username %> <%= button_to "Invite", invitations_path(event_id: @event.id, user_id: user.id) %></p>
                        <% end %>
                    <% end %>
                <% end %>
            </ul>
    <% else %>
        <p> There are currently no other users to invite.</p>
    <% end %>
    <p>Would you like to edit or delete this event?</p>
    <%= button_to "~Edit the event~", edit_event_path(@event), method: :get %>
    <%= button_to "! Delete the event !", event_path, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this event?" } %>
<% elsif !@event.attendees.where(id: current_user.id).any? %>
    <p>Would you like to join this event?</p>
    <%= button_to "Join the event!", attendings_path(event_id: @event.id) %> 
<% end %>