<h1>Events created by <%= @user.email %></h1>

<% if @user.created_events.any? %>
    <% @user.created_events.each do |event| %>
        <p>Event date: <%= event.event_date %></p>
        <p>Location: <%= event.location %></p>
        <p>-----------</p>
    <% end %>
<% else %>
    <p>No events created by this user yet.</p>
<% end %>